{
  "name": "node-gui",
  "version": "1.0.2",
  "description": "Native GUI window with embedded browser control for Node.js applications. Opens a webview pointing to a local port so Node apps can include a GUI without requiring users to open a browser manually.",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "node-gui-pack": "bin/pack.js"
  },
  "scripts": {
    "install": "node scripts/install-webview2.js && node-gyp rebuild",
    "build": "node scripts/install-webview2.js && node-gyp rebuild",
    "test": "node test/test.js && node test/test_pack.js",
    "demo": "node test/test_hello_gui.js",
    "demo:pack": "node bin/pack.js"
  },
  "node-gui": {
    "pack": {
      "output": "dist/hello-gui",
      "main": "test/test_hello_gui.js",
      "exclude": ["src", "deps", "test/test.js", "test/test_pack.js", "scripts", ".gitignore", "binding.gyp", "README.md", "build/Release/obj", "*.pdb", "*.iobj", "*.ipdb", "*.lib", "*.exp", "node_modules/*", "!node_modules/node-addon-api"]
    }
  },
  "keywords": [
    "gui",
    "webview",
    "native",
    "napi",
    "window",
    "browser",
    "webview2",
    "webkit",
    "wkwebview"
  ],
  "author": "tomika",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomika/node-gui.git"
  },
  "homepage": "https://github.com/tomika/node-gui#readme",
  "bugs": {
    "url": "https://github.com/tomika/node-gui/issues"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin/",
    "lib/",
    "src/",
    "scripts/",
    "binding.gyp",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0",
    "jimp": "^0.22.0"
  },
  "devDependencies": {
    "node-gyp": "^11.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "win32",
    "linux",
    "darwin"
  ],
  "gypfile": true
}
